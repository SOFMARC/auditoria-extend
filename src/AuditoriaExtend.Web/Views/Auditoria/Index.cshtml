@using AuditoriaExtend.Application.DTOs
@{
    ViewData["Title"] = "Dashboard de Auditoria";
    var stats = ViewBag.Estatisticas as EstatisticasRevisaoDto;
}

<div class="row mb-4">
    <div class="col">
        <h2><i class="fas fa-chart-bar me-2 text-primary"></i>Dashboard de Auditoria</h2>
        <p class="text-muted">Visão geral do processo de auditoria de pedidos e guias médicas.</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-center border-primary">
            <div class="card-body">
                <i class="fas fa-layer-group fa-2x text-primary mb-2"></i>
                <h4 class="mb-0">@ViewBag.TotalLotes</h4>
                <small class="text-muted">Total de Lotes</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-warning">
            <div class="card-body">
                <i class="fas fa-exclamation-triangle fa-2x text-warning mb-2"></i>
                <h4 class="mb-0">@ViewBag.TotalDivergencias</h4>
                <small class="text-muted">Divergências Pendentes</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-success">
            <div class="card-body">
                <i class="fas fa-check-circle fa-2x text-success mb-2"></i>
                <h4 class="mb-0">@(stats?.TotalRevisados ?? 0)</h4>
                <small class="text-muted">Revisões Realizadas</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-info">
            <div class="card-body">
                <i class="fas fa-percentage fa-2x text-info mb-2"></i>
                <h4 class="mb-0">@(stats?.TaxaAceitacao ?? 0)%</h4>
                <small class="text-muted">Taxa de Aceitação</small>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header"><h5 class="mb-0">Ações Rápidas</h5></div>
            <div class="card-body d-flex flex-column gap-2">
                <a asp-action="Divergencias" class="btn btn-outline-warning">
                    <i class="fas fa-exclamation-triangle me-2"></i>Ver Todas as Divergências
                </a>
                <a asp-controller="RevisaoHumana" asp-action="Fila" class="btn btn-outline-primary">
                    <i class="fas fa-tasks me-2"></i>Fila de Revisão Humana
                </a>
                <a asp-controller="Importacao" asp-action="Upload" class="btn btn-outline-success">
                    <i class="fas fa-upload me-2"></i>Importar Novo Lote
                </a>
                <a asp-action="Relatorio" class="btn btn-outline-secondary">
                    <i class="fas fa-download me-2"></i>Exportar Relatório CSV
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header"><h5 class="mb-0">Status das Revisões</h5></div>
            <div class="card-body">
                @if (stats != null && stats.TotalRevisados > 0)
                {
                    <div class="mb-2">
                        <div class="d-flex justify-content-between small mb-1">
                            <span>Aceitos</span><span>@stats.TotalAceitos</span>
                        </div>
                        <div class="progress" style="height:8px">
                            <div class="progress-bar bg-success" style="width:@(stats.TotalAceitos * 100 / stats.TotalRevisados)%"></div>
                        </div>
                    </div>
                    <div class="mb-2">
                        <div class="d-flex justify-content-between small mb-1">
                            <span>Rejeitados</span><span>@stats.TotalRejeitados</span>
                        </div>
                        <div class="progress" style="height:8px">
                            <div class="progress-bar bg-danger" style="width:@(stats.TotalRejeitados * 100 / stats.TotalRevisados)%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="d-flex justify-content-between small mb-1">
                            <span>Correções Solicitadas</span><span>@stats.TotalCorrecoesSolicitadas</span>
                        </div>
                        <div class="progress" style="height:8px">
                            <div class="progress-bar bg-warning" style="width:@(stats.TotalCorrecoesSolicitadas * 100 / stats.TotalRevisados)%"></div>
                        </div>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center py-3">Nenhuma revisão realizada ainda.</p>
                }
            </div>
        </div>
    </div>
</div>
