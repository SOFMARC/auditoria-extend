@using AuditoriaExtend.Application.Common
@using AuditoriaExtend.Application.DTOs
@model PaginatedList<RevisaoHumanaDto>
@{
    ViewData["Title"] = "Histórico de Revisões";
}

<div class="row mb-4">
    <div class="col">
        <h2><i class="fas fa-history me-2 text-secondary"></i>Histórico de Revisões</h2>
        <p class="text-muted">@Model.TotalCount revisões realizadas.</p>
    </div>
    <div class="col-auto d-flex gap-2">
        <a asp-action="Fila" class="btn btn-outline-warning">
            <i class="fas fa-tasks me-1"></i>Fila de Revisão
        </a>
        <a asp-action="Relatorio" class="btn btn-outline-success">
            <i class="fas fa-download me-1"></i>Exportar CSV
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.Items.Any())
        {
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Divergência</th>
                        <th>Decisão</th>
                        <th>Auditor</th>
                        <th>Justificativa</th>
                        <th>Data Revisão</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var rev in Model.Items)
                    {
                        var (cls, ic) = rev.Decisao switch
                        {
                            AuditoriaExtend.Domain.Enums.StatusDivergencia.Aceita => ("success", "check-circle"),
                            AuditoriaExtend.Domain.Enums.StatusDivergencia.Rejeitada => ("danger", "times-circle"),
                            AuditoriaExtend.Domain.Enums.StatusDivergencia.CorrecaoSolicitada => ("warning", "edit"),
                            _ => ("secondary", "clock")
                        };
                        <tr>
                            <td class="text-muted">#@rev.Id</td>
                            <td>
                                <a asp-action="Revisar" asp-route-id="@rev.DivergenciaId" class="text-decoration-none">
                                    Divergência #@rev.DivergenciaId
                                </a>
                            </td>
                            <td>
                                <span class="badge bg-@cls">
                                    <i class="fas fa-@ic me-1"></i>@rev.Decisao
                                </span>
                            </td>
                            <td>@rev.NomeAuditor</td>
                            <td>
                                <small class="text-muted">
                                    @(rev.Justificativa?.Length > 50 ? rev.Justificativa[..50] + "..." : rev.Justificativa ?? "-")
                                </small>
                            </td>
                            <td><small class="text-muted">@rev.DataRevisao.ToString("dd/MM/yyyy HH:mm")</small></td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="px-3 pb-3">
                @await Html.PartialAsync("_Pagination", Model)
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-history fa-3x mb-3"></i>
                <p>Nenhuma revisão realizada ainda.</p>
            </div>
        }
    </div>
</div>
