@using AuditoriaExtend.Application.DTOs
@using AuditoriaExtend.Domain.Enums
@model DivergenciaAuditoriaDto
@{
    ViewData["Title"] = $"Revisar Divergência #{Model.Id}";
    var (sevClass, sevIcon) = Model.Severidade switch
    {
        SeveridadeDivergencia.Critica => ("danger",    "skull-crossbones"),
        SeveridadeDivergencia.Alta    => ("warning",   "exclamation-circle"),
        SeveridadeDivergencia.Media   => ("info",      "info-circle"),
        _                             => ("secondary", "minus-circle")
    };
    var temDados = !string.IsNullOrWhiteSpace(Model.DadosExtaidosDocumento)
                   && Model.DadosExtaidosDocumento != "{}";
    var temArquivo = !string.IsNullOrWhiteSpace(Model.UrlDocumentoOriginal);
}

<div class="row mb-3">
    <div class="col">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Fila">Fila de Revisão</a></li>
                <li class="breadcrumb-item active">Divergência #@Model.Id</li>
            </ol>
        </nav>
        <h2><i class="fas fa-gavel me-2 text-primary"></i>Revisar Divergência #@Model.Id</h2>
    </div>
</div>

<div class="row g-4">

    @* ── Coluna esquerda: detalhes + documento + dados extraídos ── *@
    <div class="col-lg-7">

        @* Detalhes da divergência *@
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-exclamation-triangle me-2"></i>Detalhes da Divergência</h5>
                <span class="badge bg-@sevClass fs-6">
                    <i class="fas fa-@sevIcon me-1"></i>@Model.SeveridadeLabel
                </span>
            </div>
            <div class="card-body">
                <table class="table table-sm table-borderless mb-0">
                    <tr><th class="text-muted" style="width:35%">Documento</th>
                        <td>
                            <strong>@Model.NomeArquivoDocumento</strong>
                            @if (temArquivo)
                            {
                                <button type="button" class="btn btn-sm btn-outline-primary ms-2"
                                        onclick="abrirDocumento('/RevisaoHumana/VisualizarDocumento?url=@Uri.EscapeDataString(Model.UrlDocumentoOriginal)', '@Model.NomeArquivoDocumento')"
                                        title="Visualizar documento original">
                                    <i class="fas fa-eye me-1"></i>Ver Documento
                                </button>
                            }
                        </td>
                    </tr>
                    @if (!string.IsNullOrEmpty(Model.TipoDocumentoLabel))
                    {
                        <tr><th class="text-muted">Tipo do Doc.</th><td><span class="badge bg-secondary">@Model.TipoDocumentoLabel</span></td></tr>
                    }
                    <tr><th class="text-muted">Tipo Divergência</th><td>@Model.Tipo</td></tr>
                    <tr><th class="text-muted">Status Atual</th><td><span class="badge bg-secondary">@Model.StatusLabel</span></td></tr>
                    <tr><th class="text-muted">Descrição</th><td>@Model.Descricao</td></tr>
                    @if (!string.IsNullOrEmpty(Model.CampoAfetado))
                    {
                        <tr><th class="text-muted">Campo Afetado</th><td><code>@Model.CampoAfetado</code></td></tr>
                    }
                    @if (!string.IsNullOrEmpty(Model.ValorEncontrado))
                    {
                        <tr><th class="text-muted">Valor Encontrado</th><td><span class="text-danger fw-semibold">@Model.ValorEncontrado</span></td></tr>
                    }
                    @if (!string.IsNullOrEmpty(Model.ValorEsperado))
                    {
                        <tr><th class="text-muted">Valor Esperado</th><td><span class="text-success fw-semibold">@Model.ValorEsperado</span></td></tr>
                    }
                    @if (Model.ValorConfianca.HasValue)
                    {
                        <tr>
                            <th class="text-muted">Confiança OCR</th>
                            <td>
                                <div class="progress d-inline-block" style="height:8px;width:100px;vertical-align:middle">
                                    <div class="progress-bar @(Model.ValorConfianca < 0.5 ? "bg-danger" : "bg-warning")"
                                         style="width:@(Model.ValorConfianca * 100)%"></div>
                                </div>
                                <span class="ms-2">@(Model.ValorConfianca.Value.ToString("P0"))</span>
                            </td>
                        </tr>
                    }
                    <tr><th class="text-muted">Detectado em</th><td>@Model.DataCriacao.ToString("dd/MM/yyyy HH:mm")</td></tr>
                </table>
                @if (!string.IsNullOrEmpty(Model.DetalhesTecnicos))
                {
                    <div class="mt-2">
                        <small class="text-muted fw-semibold">Detalhes Técnicos:</small>
                        <pre class="bg-light rounded p-2 small mt-1">@Model.DetalhesTecnicos</pre>
                    </div>
                }
            </div>
        </div>

        @* Dados extraídos do documento *@
        @if (temDados)
        {
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-database me-2 text-info"></i>Dados Importados do Documento</h5>
                    <div class="d-flex gap-2">
                        @if (temArquivo)
                        {
                            <button type="button" class="btn btn-sm btn-outline-primary"
                                    onclick="abrirDocumento('/RevisaoHumana/VisualizarDocumento?url=@Uri.EscapeDataString(Model.UrlDocumentoOriginal)', '@Model.NomeArquivoDocumento')">

                                <i class="fas fa-file-image me-1"></i>Ver Arquivo Original
                            </button>
                        }
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="copiarDados()">
                            <i class="fas fa-copy me-1"></i>Copiar JSON
                        </button>
                    </div>
                </div>
                <div class="card-body p-0">
                    @{
                        Newtonsoft.Json.Linq.JObject? dadosObj = null;
                        try { dadosObj = Newtonsoft.Json.Linq.JObject.Parse(Model.DadosExtaidosDocumento!); } catch { }
                    }
                    @if (dadosObj != null)
                    {
                        <table class="table table-sm table-striped mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:35%">Campo</th>
                                    <th>Valor</th>
                                    <th style="width:12%" class="text-center">Confiança</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var prop in dadosObj.Properties())
                                {
                                    var valToken = prop.Value["value"];
                                    var confToken = prop.Value["confidence"];
                                    var val = valToken?.ToString() ?? prop.Value.ToString();
                                    double? conf = null;
                                    if (confToken != null && double.TryParse(confToken.ToString(), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var cv))
                                        conf = cv;

                                    if (string.IsNullOrWhiteSpace(val) || val == "null") continue;

                                    <tr>
                                        <td><code class="small">@prop.Name</code></td>
                                        <td>
                                            @if (valToken?.Type == Newtonsoft.Json.Linq.JTokenType.Array)
                                            {
                                                <ul class="mb-0 ps-3 small">
                                                    @foreach (var item in valToken)
                                                    {
                                                        <li>@item.ToString()</li>
                                                    }
                                                </ul>
                                            }
                                            else
                                            {
                                                <span class="small">@val</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (conf.HasValue)
                                            {
                                                var pct = (int)(conf.Value * 100);
                                                var cc = pct >= 90 ? "success" : pct >= 70 ? "warning" : "danger";
                                                <span class="badge bg-@cc">@pct%</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">-</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <div class="p-2 border-top">
                            <a href="#jsonRaw" data-bs-toggle="collapse" class="small text-muted">
                                <i class="fas fa-code me-1"></i>Ver JSON bruto
                            </a>
                            <div id="jsonRaw" class="collapse mt-2">
                                <pre class="bg-dark text-light p-2 rounded small" style="max-height:300px;overflow:auto">@{
                                    try {
                                        var pretty = Newtonsoft.Json.Linq.JToken.Parse(Model.DadosExtaidosDocumento!).ToString(Newtonsoft.Json.Formatting.Indented);
                                        @pretty
                                    } catch {
                                        @Model.DadosExtaidosDocumento
                                    }
                                }</pre>
                            </div>
                        </div>
                    }
                    else
                    {
                        <pre id="jsonBruto" class="bg-dark text-light p-3 mb-0 rounded-bottom small" style="max-height:400px;overflow:auto">@Model.DadosExtaidosDocumento</pre>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-secondary">
                <i class="fas fa-info-circle me-2"></i>Dados extraídos não disponíveis para este documento.
                @if (temArquivo)
                {
                    <button type="button" class="btn btn-sm btn-outline-primary ms-2"
                            onclick="abrirDocumento('@Url.Action("VisualizarDocumento", "RevisaoHumana")?url=@Uri.EscapeDataString(Model.UrlDocumentoOriginal ?? "")', '@Model.NomeArquivoDocumento')">
                        <i class="fas fa-eye me-1"></i>Ver Arquivo Original
                    </button>
                }
            </div>
        }
    </div>

    @* ── Coluna direita: ações ── *@
    <div class="col-lg-5">

        @* Aceitar — sem campos obrigatórios *@
        <div class="card border-success mb-3">
            <div class="card-header bg-success text-white">
                <h6 class="mb-0"><i class="fas fa-check me-2"></i>Aceitar</h6>
            </div>
            <div class="card-body">
                <p class="small text-muted mb-3">Confirma que a divergência é válida e está correta. Nenhuma informação adicional necessária.</p>
                <form asp-action="Aceitar" method="post">
                    <input type="hidden" name="divergenciaId" value="@Model.Id" />
                    <input type="hidden" name="nomeAuditor" value="Sistema" />
                    <button type="submit" class="btn btn-success w-100">
                        <i class="fas fa-check me-1"></i>Aceitar Divergência
                    </button>
                </form>
            </div>
        </div>
@* @* 
        @* Rejeitar — sem campos obrigatórios *@
        @* <div class="card border-danger mb-3">
            <div class="card-header bg-danger text-white">
                <h6 class="mb-0"><i class="fas fa-times me-2"></i>Rejeitar</h6>
            </div>
            <div class="card-body">
                <p class="small text-muted mb-3">Indica que a divergência é um falso positivo e deve ser descartada.</p>
                <form asp-action="Rejeitar" method="post">
                    <input type="hidden" name="divergenciaId" value="@Model.Id" />
                    <input type="hidden" name="nomeAuditor" value="Sistema" />
                    <input type="hidden" name="justificativa" value="Rejeitado pelo auditor." />
                    <button type="submit" class="btn btn-danger w-100">
                        <i class="fas fa-times me-1"></i>Rejeitar Divergência
                    </button>
                </form>
            </div>
        </div> *@

        @* Correção — com nome, justificativa e o que corrigir *@
        <div class="card border-warning mb-3">
            <div class="card-header bg-warning">
                <h6 class="mb-0"><i class="fas fa-edit me-2"></i>Solicitar Correção</h6>
            </div>
            <div class="card-body">
                <p class="small text-muted mb-3">Solicita correção do documento ou dado. Preencha os campos abaixo.</p>
                <form asp-action="SolicitarCorrecao" method="post">
                    <input type="hidden" name="divergenciaId" value="@Model.Id" />
                    <div class="mb-2">
                        <label class="form-label small fw-semibold mb-1">Seu nome <span class="text-danger">*</span></label>
                        <input type="text" name="nomeAuditor" class="form-control form-control-sm"
                               placeholder="Nome do responsável pela correção" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small fw-semibold mb-1">Observação da correção</label>
                        <textarea name="observacaoCorrecao"
                                  class="form-control form-control-sm"
                                  rows="2"
                                  placeholder="Detalhes adicionais da correção"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold mb-1">
                            Novo valor corrigido <span class="text-danger">*</span>
                        </label>
                        <textarea name="alteracoesJson"
                                  class="form-control form-control-sm"
                                  rows="6"
                                  required></textarea>
                    </div>
                    <button type="submit" class="btn btn-warning w-100">
                        <i class="fas fa-edit me-1"></i>Solicitar Correção
                    </button>
                </form>
            </div>
        </div>

        <a asp-action="Fila" class="btn btn-outline-secondary w-100">
            <i class="fas fa-arrow-left me-1"></i>Voltar à Fila
        </a>
    </div>
</div>

@* ── Modal: visualização do documento original (TIFF/PDF/imagem) ── *@
<div class="modal fade" id="modalDocumento" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-scrollable" style="max-width:90vw">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-file-image me-2"></i><span id="modalDocNome"></span></h5>
                <div class="d-flex gap-2 align-items-center">
                    <div id="zoomControls" class="d-none">
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="zoomOut()" title="Diminuir">
                            <i class="fas fa-search-minus"></i>
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="resetZoom()" title="Tamanho original">
                            100%
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="zoomIn()" title="Aumentar">
                            <i class="fas fa-search-plus"></i>
                        </button>
                    </div>

                    <a id="modalDocLink" href="#" target="_blank" class="btn btn-sm btn-outline-secondary">
                        <i class="fas fa-external-link-alt me-1"></i>Abrir em nova aba
                    </a>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
            </div>
            <div class="modal-body p-0 bg-dark" style="min-height:70vh">
                <div id="modalDocSpinner" class="py-5">
                    <div class="spinner-border text-light"></div>
                    <p class="text-light mt-2">Carregando documento...</p>
                </div>
                @* Container de imagem (TIFF/PNG/JPG) *@
                <div id="modalDocImageWrap"
                     class="d-none w-100 h-100 overflow-auto text-center"
                     style="max-height:85vh;">
                    <img id="modalDocImg"
                         src=""
                         alt="Documento"
                         style="max-width:100%; height:auto; cursor:grab;" />
                </div>

                <iframe id="modalDocPdf" src="" class="d-none w-100 border-0" style="height:85vh"></iframe>
                @* Fallback: link para abrir externamente *@
                <div id="modalDocFallback" class="d-none py-5 text-light">
                    <i class="fas fa-file fa-3x mb-3"></i>
                    <p>Não foi possível exibir o arquivo diretamente no navegador.</p>
                    <a id="modalDocFallbackLink" href="#" target="_blank" class="btn btn-outline-light">
                        <i class="fas fa-external-link-alt me-1"></i>Abrir arquivo em nova aba
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@panzoom/panzoom/dist/panzoom.min.js"></script>
    <script>
        const modalDocSpinner = document.getElementById('modalDocSpinner');
        const modalDocImg = document.getElementById('modalDocImg');
        const modalDocPdf = document.getElementById('modalDocPdf');
        const modalDocFallback = document.getElementById('modalDocFallback');
        const modalDocNome = document.getElementById('modalDocNome');
        const modalDocLink = document.getElementById('modalDocLink');
        const modalDocFallbackLink = document.getElementById('modalDocFallbackLink');
        const modalDocImageWrap = document.getElementById('modalDocImageWrap');
        const zoomControls = document.getElementById('zoomControls');

        let panzoomInstance = null;
        let wheelHandler = null;

        function resetDocumentoModal() {
            modalDocSpinner.classList.remove('d-none');
            modalDocImageWrap.classList.add('d-none');
            modalDocPdf.classList.add('d-none');
            modalDocFallback.classList.add('d-none');

            modalDocImg.src = '';
            modalDocPdf.src = '';

            zoomControls.classList.add('d-none');

            if (wheelHandler) {
                modalDocImageWrap.removeEventListener('wheel', wheelHandler);
                wheelHandler = null;
            }

            if (panzoomInstance) {
                panzoomInstance.destroy();
                panzoomInstance = null;
            }

            modalDocImg.style.transform = '';
            modalDocImg.style.cursor = 'grab';
        }

        function mostrarFallback() {
            modalDocSpinner.classList.add('d-none');
            modalDocImageWrap.classList.add('d-none');
            modalDocPdf.classList.add('d-none');
            modalDocFallback.classList.remove('d-none');
            zoomControls.classList.add('d-none');
        }

        function iniciarPanzoom() {
            if (panzoomInstance) {
                panzoomInstance.destroy();
                panzoomInstance = null;
            }

            panzoomInstance = Panzoom(modalDocImg, {
                maxScale: 5,
                minScale: 1,
                contain: 'outside',
                cursor: 'grab'
            });

            wheelHandler = function (e) {
                e.preventDefault();
                panzoomInstance.zoomWithWheel(e);
            };

            modalDocImageWrap.addEventListener('wheel', wheelHandler, { passive: false });

            modalDocImg.addEventListener('mousedown', function () {
                modalDocImg.style.cursor = 'grabbing';
            });

            window.addEventListener('mouseup', function () {
                modalDocImg.style.cursor = 'grab';
            });
        }

        function zoomIn() {
            if (panzoomInstance) {
                panzoomInstance.zoomIn();
            }
        }

        function zoomOut() {
            if (panzoomInstance) {
                panzoomInstance.zoomOut();
            }
        }

        function resetZoom() {
            if (panzoomInstance) {
                panzoomInstance.reset();
            }
        }

        modalDocImg.onload = function () {
            modalDocSpinner.classList.add('d-none');
            modalDocImageWrap.classList.remove('d-none');
            zoomControls.classList.remove('d-none');
            iniciarPanzoom();
        };

        modalDocImg.onerror = function () {
            mostrarFallback();
        };

        modalDocPdf.onload = function () {
            modalDocSpinner.classList.add('d-none');
            modalDocPdf.classList.remove('d-none');
            zoomControls.classList.add('d-none');
        };

        function abrirDocumento(url, nome) {
            modalDocNome.textContent = nome;
            modalDocLink.href = url;
            modalDocFallbackLink.href = url;

            resetDocumentoModal();

            var nomeLower = nome.toLowerCase();

            if (nomeLower.endsWith('.pdf')) {
                modalDocPdf.src = url;
            } else {
                modalDocImg.src = url;
            }

            new bootstrap.Modal(document.getElementById('modalDocumento')).show();
        }

        function copiarDados() {
            var json = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DadosExtaidosDocumento ?? "{}"));
            navigator.clipboard.writeText(json).then(function () {
                var btn = event.target.closest('button');
                btn.innerHTML = '<i class="fas fa-check me-1"></i>Copiado!';
                setTimeout(function () {
                    btn.innerHTML = '<i class="fas fa-copy me-1"></i>Copiar JSON';
                }, 2000);
            });
        }
    </script>
}
