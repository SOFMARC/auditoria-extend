@using System.Text.Encodings.Web
@using AuditoriaExtend.Application.DTOs
@using AuditoriaExtend.Domain.Enums
@model LoteDto
@{
    ViewData["Title"] = $"Lote #{Model.Id}";
    var documentos = ViewBag.Documentos as List<DocumentoDto> ?? new List<DocumentoDto>();
    var divergenciasPorDoc = ViewBag.DivergenciasPorDoc as Dictionary<int, List<DivergenciaAuditoriaDto>>
                             ?? new Dictionary<int, List<DivergenciaAuditoriaDto>>();
}

<div class="row mb-4">
    <div class="col">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index">Importação</a></li>
                <li class="breadcrumb-item"><a asp-action="Historico">Histórico</a></li>
                <li class="breadcrumb-item active">Lote #@Model.Id</li>
            </ol>
        </nav>
        <h2><i class="fas fa-file-archive me-2 text-primary"></i>@Model.NomeArquivo</h2>
    </div>
    <div class="col-auto d-flex gap-2">
        @if (Model.Status == StatusLote.Pendente)
        {
            <form asp-action="Processar" asp-route-id="@Model.Id" method="post">
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-play me-1"></i>Processar Lote
                </button>
            </form>
        }
        <a asp-action="Historico" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Voltar
        </a>
    </div>
</div>

@* ── Cards de resumo ── *@
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-center h-100">
            <div class="card-body">
                @{
                    var (cls, ic) = Model.Status switch
                    {
                        StatusLote.Concluido   => ("success", "check-circle"),
                        StatusLote.Processando => ("warning", "spinner fa-spin"),
                        StatusLote.Erro        => ("danger", "times-circle"),
                        _                      => ("secondary", "clock")
                    };
                }
                <i class="fas fa-@ic fa-2x text-@cls mb-2"></i>
                <h5 class="mb-0">@Model.Status</h5>
                <small class="text-muted">Status</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center h-100">
            <div class="card-body">
                <i class="fas fa-file fa-2x text-primary mb-2"></i>
                <h5 class="mb-0">@Model.QuantidadeProcessados / @Model.QuantidadeDocumentos</h5>
                <small class="text-muted">Documentos Processados</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center h-100">
            <div class="card-body">
                <i class="fas fa-exclamation-triangle fa-2x text-warning mb-2"></i>
                <h5 class="mb-0">@Model.QuantidadeDivergencias</h5>
                <small class="text-muted">Divergências</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center h-100">
            <div class="card-body">
                <i class="fas fa-percentage fa-2x text-info mb-2"></i>
                <h5 class="mb-0">@Model.PercentualProcessado%</h5>
                <small class="text-muted">Progresso</small>
            </div>
        </div>
    </div>
</div>

@* ── Informações do lote ── *@
<div class="card mb-3">
    <div class="card-header"><h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Informações do Lote</h5></div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <table class="table table-sm table-borderless">
                    <tr><th class="text-muted" style="width:40%">ID</th><td>#@Model.Id</td></tr>
                    <tr><th class="text-muted">Arquivo</th><td>@Model.NomeArquivo</td></tr>
                    <tr><th class="text-muted">Tamanho</th><td>@((Model.TamanhoArquivo / 1024.0 / 1024.0).ToString("F2")) MB</td></tr>
                </table>
            </div>
            <div class="col-md-6">
                <table class="table table-sm table-borderless">
                    <tr><th class="text-muted" style="width:40%">Criado em</th><td>@Model.DataCriacao.ToString("dd/MM/yyyy HH:mm")</td></tr>
                    <tr><th class="text-muted">Concluído em</th><td>@(Model.DataFimProcessamento?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td></tr>
                </table>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(Model.MensagemErro))
        {
            <div class="alert alert-danger mt-2 mb-0">
                <i class="fas fa-times-circle me-2"></i><strong>Erro:</strong> @Model.MensagemErro
            </div>
        }
    </div>
</div>

@* ── Banner de divergências ── *@
@if (Model.QuantidadeDivergencias > 0)
{
    <div class="alert alert-warning d-flex align-items-center justify-content-between mb-3">
        <span><i class="fas fa-exclamation-triangle me-2"></i>
            Este lote possui <strong>@Model.QuantidadeDivergencias divergência(s)</strong> aguardando revisão.
        </span>
        <a asp-controller="RevisaoHumana" asp-action="Fila" class="btn btn-warning btn-sm">
            <i class="fas fa-tasks me-1"></i>Ir para Revisão
        </a>
    </div>
}

@* ── Lista de documentos ── *@
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="fas fa-list me-2"></i>Documentos do Lote (@documentos.Count)</h5>
    </div>
    <div class="card-body p-0">
        @if (documentos.Any())
        {
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:3%" class="ps-3">#</th>
                        <th>Arquivo</th>
                        <th style="width:12%">Tipo</th>
                        <th style="width:10%">Status</th>
                        <th style="width:8%">OCR</th>
                        <th style="width:12%" class="text-center">Divergências</th>
                        <th style="width:12%" class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doc in documentos)
                    {
                        var divs = divergenciasPorDoc.TryGetValue(doc.Id, out var d) ? d : new List<DivergenciaAuditoriaDto>();
                        var qtdPendentes = divs.Count(x => x.Status == StatusDivergencia.Pendente);
                        var qtdTotal = divs.Count;

                        var rowCls = doc.Status switch
                        {
                            StatusDocumento.Erro      => "table-danger",
                            StatusDocumento.Processado when qtdPendentes > 0 => "table-warning",
                            StatusDocumento.Processado => "",
                            _ => "table-secondary"
                        };

                        var (stBadge, stIcon) = doc.Status switch
                        {
                            StatusDocumento.Processado       => ("success",   "check-circle"),
                            StatusDocumento.Erro             => ("danger",    "times-circle"),
                            StatusDocumento.EnviadoExtend    => ("info",      "paper-plane"),
                            StatusDocumento.AguardandoExtend => ("warning",   "hourglass-half"),
                            _                                => ("secondary", "clock")
                        };

                        <tr class="@rowCls">
                            <td class="text-muted ps-3"><small>#@doc.Id</small></td>
                            <td>
                                <span class="fw-semibold small">@doc.NomeArquivo</span>
                                @if (doc.OrigemSuspeita)
                                {
                                    <span class="badge bg-danger ms-1" title="Origem suspeita"><i class="fas fa-skull-crossbones"></i></span>
                                }
                                @if (doc.RevisaoHumanaNecessaria)
                                {
                                    <span class="badge bg-warning text-dark ms-1" title="Revisão humana necessária"><i class="fas fa-user-check"></i></span>
                                }
                                @if (!string.IsNullOrEmpty(doc.MensagemErro))
                                {
                                    <br /><small class="text-danger"><i class="fas fa-exclamation-circle me-1"></i>@doc.MensagemErro</small>
                                }
                            </td>
                            <td><span class="badge bg-secondary">@doc.TipoLabel</span></td>
                            <td>
                                <span class="badge bg-@stBadge">
                                    <i class="fas fa-@stIcon me-1"></i>@doc.StatusLabel
                                </span>
                            </td>
                            <td>
                                @if (doc.Status == StatusDocumento.Processado)
                                {
                                    var ocrPct = (int)(doc.ConfiancaOcr * 100);
                                    var ocrCls = ocrPct >= 90 ? "success" : ocrPct >= 70 ? "warning" : "danger";
                                    <div class="d-flex align-items-center gap-1">
                                        <div class="progress flex-grow-1" style="height:6px">
                                            <div class="progress-bar bg-@ocrCls" style="width:@ocrPct%"></div>
                                        </div>
                                        <small class="text-muted">@ocrPct%</small>
                                    </div>
                                }
                                else
                                {
                                    <small class="text-muted">-</small>
                                }
                            </td>
                            <td class="text-center">
                                @if (qtdTotal == 0)
                                {
                                    <span class="badge bg-success"><i class="fas fa-check me-1"></i>OK</span>
                                }
                                else
                                {
                                    @* Mostra apenas a contagem + botão para ver a lista de divergências deste documento *@
                                    var divBadgeCls = qtdPendentes > 0 ? "warning" : "secondary";
                                    var divBadgeIco = qtdPendentes > 0 ? "exclamation-triangle" : "check-circle";
                                    <button type="button"
                                            class="btn btn-sm btn-@divBadgeCls"
                                            title="Ver @qtdTotal divergência(s) deste documento"
                                            onclick="abrirDivergencias(@doc.Id, '@JavaScriptEncoder.Default.Encode(doc.NomeArquivo)')">
                                        <i class="fas fa-@divBadgeIco me-1"></i>@qtdTotal
                                    </button>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-flex gap-1 justify-content-center">
                                    @if (!string.IsNullOrWhiteSpace(doc.DadosExtraidos) && doc.DadosExtraidos != "{}")
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-outline-primary"
                                                title="Ver dados extraídos (JSON)"
                                                onclick="abrirJson(@doc.Id, '@JavaScriptEncoder.Default.Encode(doc.NomeArquivo)', '@JavaScriptEncoder.Default.Encode(doc.DadosExtraidos ?? "{}")')">
                                            <i class="fas fa-code"></i>
                                        </button>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(doc.UrlDocumento))
                                    {
                                        <a href="@doc.UrlDocumento" target="_blank"
                                           class="btn btn-sm btn-outline-secondary"
                                           title="Abrir documento original">
                                            <i class="fas fa-file-image"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-inbox fa-3x mb-3"></i>
                <p>Nenhum documento encontrado neste lote.</p>
                @if (Model.Status == StatusLote.Pendente)
                {
                    <form asp-action="Processar" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-play me-1"></i>Processar Lote
                        </button>
                    </form>
                }
            </div>
        }
    </div>
</div>

@* ── Modal: Lista de divergências do documento ── *@
<div class="modal fade" id="modalDivergencias" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-exclamation-triangle me-2 text-warning"></i>Divergências — <span id="modalDivNome"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0" id="modalDivBody">
                <div class="text-center py-4"><div class="spinner-border text-warning"></div></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
            </div>
        </div>
    </div>
</div>

@* ── Modal: JSON dos dados extraídos ── *@
<div class="modal fade" id="modalJson" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-code me-2"></i>Dados Extraídos — <span id="modalJsonNome"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <pre id="modalJsonConteudo" class="bg-dark text-light p-3 mb-0 rounded-bottom" style="font-size:0.8rem;max-height:70vh;overflow:auto"></pre>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="copiarJson()">
                    <i class="fas fa-copy me-1"></i>Copiar JSON
                </button>
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Fechar</button>
            </div>
        </div>
    </div>
</div>

@* ── Dados das divergências embutidos para o modal ── *@
<script>
    var _divsPorDoc = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        divergenciasPorDoc.ToDictionary(
            kv => kv.Key,
            kv => kv.Value.Select(div => new {
                id = div.Id,
                descricao = div.Descricao,
                severidade = div.SeveridadeLabel,
                status = div.StatusLabel,
                tipo = div.Tipo.ToString(),
                campo = div.CampoAfetado ?? "",
                valorEncontrado = div.ValorEncontrado ?? "",
                valorEsperado = div.ValorEsperado ?? ""
            }).ToList()
        )
    ));

    var _jsonAtual = '';

    function abrirDivergencias(docId, nomeArquivo) {
        document.getElementById('modalDivNome').textContent = nomeArquivo;
        var divs = _divsPorDoc[docId] || [];
        var body = document.getElementById('modalDivBody');

        if (divs.length === 0) {
            body.innerHTML = '<div class="text-center py-4 text-muted"><i class="fas fa-check-circle fa-2x text-success mb-2"></i><p>Sem divergências.</p></div>';
        } else {
            var sevCls = { 'Crítica': 'danger', 'Alta': 'warning', 'Média': 'info', 'Baixa': 'secondary' };
            var rows = divs.map(function(d) {
                var cls = sevCls[d.severidade] || 'secondary';
                var extra = '';
                if (d.campo) extra += '<br><small class="text-muted">Campo: <code>' + d.campo + '</code></small>';
                if (d.valorEncontrado) extra += '<br><small class="text-danger">Encontrado: ' + d.valorEncontrado + '</small>';
                if (d.valorEsperado) extra += '<br><small class="text-success">Esperado: ' + d.valorEsperado + '</small>';
                return '<tr>' +
                    '<td class="ps-3"><small class="text-muted">#' + d.id + '</small></td>' +
                    '<td><span class="badge bg-' + cls + '">' + d.severidade + '</span></td>' +
                    '<td><small>' + d.tipo + '</small></td>' +
                    '<td><small>' + d.descricao + extra + '</small></td>' +
                    '<td><span class="badge bg-secondary">' + d.status + '</span></td>' +
                    '<td><a href="/RevisaoHumana/Revisar/' + d.id + '" class="btn btn-sm btn-primary"><i class="fas fa-gavel"></i></a></td>' +
                    '</tr>';
            }).join('');
            body.innerHTML = '<table class="table table-hover mb-0 align-middle">' +
                '<thead class="table-light"><tr><th class="ps-3">#</th><th>Severidade</th><th>Tipo</th><th>Descrição</th><th>Status</th><th>Ação</th></tr></thead>' +
                '<tbody>' + rows + '</tbody></table>';
        }

        new bootstrap.Modal(document.getElementById('modalDivergencias')).show();
    }

    function abrirJson(id, nome, jsonRaw) {
        _jsonAtual = jsonRaw;
        document.getElementById('modalJsonNome').textContent = nome;
        try {
            var obj = JSON.parse(jsonRaw);
            document.getElementById('modalJsonConteudo').textContent = JSON.stringify(obj, null, 2);
        } catch(e) {
            document.getElementById('modalJsonConteudo').textContent = jsonRaw;
        }
        new bootstrap.Modal(document.getElementById('modalJson')).show();
    }

    function copiarJson() {
        navigator.clipboard.writeText(_jsonAtual).then(function() {
            var btn = event.target.closest('button');
            btn.innerHTML = '<i class="fas fa-check me-1"></i>Copiado!';
            setTimeout(function() { btn.innerHTML = '<i class="fas fa-copy me-1"></i>Copiar JSON'; }, 2000);
        });
    }
</script>
